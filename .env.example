# ============================================
# COMPANY AI ASSISTANT - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values

# ----------------
# OpenAI API
# ----------------
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=30

# ----------------
# Database
# ----------------
# For Docker: Use the values below
# For Local: postgresql://postgres:YOUR_PASSWORD@localhost:5432/company_ai_asst
DATABASE_URL=postgresql://postgres:mysecretpassword@database:5432/company_ai_asst
DB_PASSWORD=mysecretpassword
DB_POOL_MIN_CONN=2
DB_POOL_MAX_CONN=10

# ----------------
# Chunking
# ----------------
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ----------------
# Retrieval
# ----------------
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.3

# ----------------
# Application
# ----------------
ENVIRONMENT=production
LOG_LEVEL=INFO
DATA_DIR=data/policies